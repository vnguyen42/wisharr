{
  "name": "wisharr",
  "version": "0.4.0",
  "description": "Sync Plex watchlists — including Plex Home managed users — to Overseerr, Radarr and Sonarr. One admin token, zero copy-paste.",
  "type": "module",
  "license": "MIT",
  "repository": "github:vnguyen42/wisharr",
  "engines": {
    "node": ">=23.4"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "sync": "tsx src/index.ts --once",
    "seed": "tsx src/index.ts --seed"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "croner": "^9.0.0",
    "fast-xml-parser": "^5.2.0",
    "hono": "^4.12.30",
    "yaml": "^2.8.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
